{
  "name": "mx-pricing",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:golden": "vitest run tests/golden/golden.test.ts",
    "test:api": "vitest run tests/api/bff.test.ts",
    "build": "npm run build -w @mx-pricing/pricing-engine && npm run build -w @mx-pricing/i18n-format && npm run build -w @mx-pricing/db && npm run build -w @mx-pricing/bff && npm run build -w @mx-pricing/web",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "npm run build -w @mx-pricing/db && DATABASE_URL=${DATABASE_URL:-postgresql://mx:mx@localhost:5432/mx_pricing} node packages/db/dist/migrate-cli.js",
    "dev:web": "npm run dev -w @mx-pricing/web",
    "dev:bff": "npm run start -w @mx-pricing/bff"
  },
  "devDependencies": {
    "pg-mem": "^3.0.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
